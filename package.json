{
  "name": "portmanager",
  "displayName": "Logical Network",
  "description": "Attach development terminals to logical networks and expose selected network ports from VS Code.",
  "version": "0.0.8084",
  "publisher": "newdlops",
  "license": "MIT",
  "icon": "media/icon.png",
  "qna": false,
  "keywords": [
    "port",
    "ports",
    "port-manager",
    "development-server",
    "network",
    "routing",
    "vscode-extension"
  ],
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/newdlops/portmanager.git"
  },
  "bugs": {
    "url": "https://github.com/newdlops/portmanager/issues"
  },
  "homepage": "https://github.com/newdlops/portmanager#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:portManager.processes",
    "onCommand:portManager.createLogicalNetwork",
    "onCommand:portManager.removeLogicalNetwork",
    "onCommand:portManager.refreshTerminals",
    "onCommand:portManager.refreshContainerServices",
    "onCommand:portManager.attachTerminalToNetwork",
    "onCommand:portManager.attachActiveTerminalToNetwork",
    "onCommand:portManager.revealTerminalWindow",
    "onCommand:portManager.attachProcessToNetwork",
    "onCommand:portManager.attachVscodeWindowTerminalsToNetwork",
    "onCommand:portManager.detachVscodeWindowTerminalsFromNetwork",
    "onCommand:portManager.copyTerminalRoutingScript",
    "onCommand:portManager.listLogicalNetworks",
    "onCommand:portManager.getTerminalRoutingScript",
    "onCommand:portManager.getTerminalDetachScript",
    "onCommand:portManager.attachContainerToNetwork",
    "onCommand:portManager.detachTerminalFromNetwork",
    "onCommand:portManager.resetTerminalNetworkSettings",
    "onCommand:portManager.addHostPortExposure",
    "onCommand:portManager.addHostAccessBinding",
    "onCommand:portManager.addComposePublishedPort",
    "onCommand:portManager.copyComposeAttachment",
    "onCommand:portManager.detachComposeAttachment",
    "onCommand:portManager.renameComposeAttachment",
    "onCommand:portManager.removeComposeAttachment",
    "onCommand:portManager.saveBindingPreset",
    "onCommand:portManager.applyBindingPreset",
    "onCommand:portManager.removeHostAccessBinding",
    "onCommand:portManager.removeHostPortExposure",
    "onCommand:portManager.copyHostPortExposureUrl",
    "onCommand:portManager.openHostPortExposureUrl",
    "onCommand:portManager.startDaemon",
    "onCommand:portManager.restartDaemon",
    "onCommand:portManager.stopDaemon",
    "onCommand:portManager.showDaemonStatus",
    "onCommand:portManager.fixStaleRouting",
    "onCommand:portManager.clearRoutingFiles",
    "onCommand:portManager.clearGlobalStorageFiles",
    "onCommand:portManager.resetRouting",
    "onCommand:portManager.clearNetworkCache",
    "onCommand:portManager.clearNetworkRoutingFiles",
    "onCommand:portManager.startManagedProcess",
    "onCommand:portManager.addExistingProcess",
    "onCommand:portManager.refresh",
    "onCommand:portManager.showStatusMenu",
    "onCommand:portManager.stopProcess",
    "onCommand:portManager.restartProcess",
    "onCommand:portManager.stopAllProcesses",
    "onCommand:portManager.copyRoutedUrl",
    "onCommand:portManager.openRoutedUrl",
    "onCommand:portManager.removeProcess",
    "onCommand:portManager.installShellHook",
    "onCommand:portManager.installExternalCli",
    "onCommand:portManager.openOwnerUi",
    "onCommand:portManager.openSettings"
  ],
  "main": "./out/src/extension/activate.js",
  "bin": {
    "portmanager": "./out/src/cli/portmanager-cli.js"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:hook",
    "compile": "tsc -p ./",
    "build:hook": "sh scripts/build-native-hook.sh",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/unit/*.test.js",
    "test:routing:stress": "npm run compile && npm run build:hook && node scripts/stress-routing.js 10000 100",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:precheck": "npm test && npm run package"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "portManager",
          "title": "Port Manager",
          "icon": "media/port-manager.svg"
        }
      ]
    },
    "views": {
      "portManager": [
        {
          "id": "portManager.processes",
          "name": "Networks"
        }
      ]
    },
    "commands": [
      {
        "command": "portManager.createLogicalNetwork",
        "title": "Port Manager: Create Logical Network",
        "category": "Port Manager",
        "icon": "$(vm)"
      },
      {
        "command": "portManager.removeLogicalNetwork",
        "title": "Port Manager: Remove Logical Network",
        "category": "Port Manager",
        "icon": "$(trash)"
      },
      {
        "command": "portManager.refreshTerminals",
        "title": "Port Manager: Refresh Terminal Windows",
        "category": "Port Manager",
        "icon": "$(refresh)"
      },
      {
        "command": "portManager.refreshContainerServices",
        "title": "Port Manager: Refresh Services",
        "category": "Port Manager",
        "icon": "$(refresh)"
      },
      {
        "command": "portManager.attachTerminalToNetwork",
        "title": "Port Manager: Attach Terminal Window to Network",
        "category": "Port Manager",
        "icon": "$(debug-console)"
      },
      {
        "command": "portManager.attachActiveTerminalToNetwork",
        "title": "Port Manager: Attach Active Terminal to Network",
        "category": "Port Manager",
        "icon": "$(terminal)"
      },
      {
        "command": "portManager.revealTerminalWindow",
        "title": "Port Manager: Reveal Terminal Window",
        "category": "Port Manager",
        "icon": "$(go-to-file)"
      },
      {
        "command": "portManager.attachProcessToNetwork",
        "title": "Port Manager: Attach Process to Network",
        "category": "Port Manager",
        "icon": "$(debug-alt)"
      },
      {
        "command": "portManager.attachVscodeWindowTerminalsToNetwork",
        "title": "Port Manager: Attach VS Code Window Terminals to Network",
        "category": "Port Manager",
        "icon": "$(terminal)"
      },
      {
        "command": "portManager.detachVscodeWindowTerminalsFromNetwork",
        "title": "Port Manager: Detach VS Code Window Terminals from Network",
        "category": "Port Manager",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "portManager.copyTerminalRoutingScript",
        "title": "Port Manager: Copy Terminal Routing Script",
        "category": "Port Manager",
        "icon": "$(copy)"
      },
      {
        "command": "portManager.attachContainerToNetwork",
        "title": "Port Manager: Attach Service to Network",
        "category": "Port Manager",
        "icon": "$(server-environment)"
      },
      {
        "command": "portManager.detachTerminalFromNetwork",
        "title": "Port Manager: Detach Terminal from Network",
        "category": "Port Manager",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "portManager.resetTerminalNetworkSettings",
        "title": "Port Manager: Reset Terminal Network Settings",
        "category": "Port Manager",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "portManager.addHostPortExposure",
        "title": "Port Manager: Add Host Port Exposure",
        "category": "Port Manager",
        "icon": "$(ports-view-icon)"
      },
      {
        "command": "portManager.addHostAccessBinding",
        "title": "Port Manager: Add Host Access Binding",
        "category": "Port Manager",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "portManager.addComposePublishedPort",
        "title": "Port Manager: Add Compose Published Port",
        "category": "Port Manager",
        "icon": "$(database)"
      },
      {
        "command": "portManager.copyComposeAttachment",
        "title": "Port Manager: Copy Compose Attachment",
        "category": "Port Manager",
        "icon": "$(copy)"
      },
      {
        "command": "portManager.detachComposeAttachment",
        "title": "Port Manager: Detach Service from Network",
        "category": "Port Manager",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "portManager.renameComposeAttachment",
        "title": "Port Manager: Rename Compose Project",
        "category": "Port Manager",
        "icon": "$(edit)"
      },
      {
        "command": "portManager.removeComposeAttachment",
        "title": "Port Manager: Remove Compose Attachment",
        "category": "Port Manager",
        "icon": "$(trash)"
      },
      {
        "command": "portManager.saveBindingPreset",
        "title": "Port Manager: Save Binding Preset",
        "category": "Port Manager",
        "icon": "$(save)"
      },
      {
        "command": "portManager.applyBindingPreset",
        "title": "Port Manager: Apply Binding Preset",
        "category": "Port Manager",
        "icon": "$(cloud-download)"
      },
      {
        "command": "portManager.removeHostAccessBinding",
        "title": "Port Manager: Remove Host Access Binding",
        "category": "Port Manager",
        "icon": "$(trash)"
      },
      {
        "command": "portManager.removeHostPortExposure",
        "title": "Port Manager: Remove Host Port Exposure",
        "category": "Port Manager",
        "icon": "$(trash)"
      },
      {
        "command": "portManager.copyHostPortExposureUrl",
        "title": "Port Manager: Copy Host Exposure URL",
        "category": "Port Manager",
        "icon": "$(copy)"
      },
      {
        "command": "portManager.openHostPortExposureUrl",
        "title": "Port Manager: Open Host Exposure URL",
        "category": "Port Manager",
        "icon": "$(link-external)"
      },
      {
        "command": "portManager.startDaemon",
        "title": "Port Manager: Start Daemon",
        "category": "Port Manager",
        "icon": "$(server-process)"
      },
      {
        "command": "portManager.restartDaemon",
        "title": "Port Manager: Restart Daemon",
        "category": "Port Manager",
        "icon": "$(debug-restart)"
      },
      {
        "command": "portManager.stopDaemon",
        "title": "Port Manager: Stop Daemon",
        "category": "Port Manager",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "portManager.showDaemonStatus",
        "title": "Port Manager: Daemon Status",
        "category": "Port Manager",
        "icon": "$(pulse)"
      },
      {
        "command": "portManager.fixStaleRouting",
        "title": "Port Manager: Fix Stale Routing",
        "category": "Port Manager",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "portManager.clearRoutingFiles",
        "title": "Port Manager: Clear All Routing Cache",
        "category": "Port Manager",
        "icon": "$(clear-all)"
      },
      {
        "command": "portManager.clearGlobalStorageFiles",
        "title": "Port Manager: Clear Global Storage Files",
        "category": "Port Manager",
        "icon": "$(clear-all)"
      },
      {
        "command": "portManager.resetRouting",
        "title": "Port Manager: Reset Routing",
        "category": "Port Manager",
        "icon": "$(clear-all)"
      },
      {
        "command": "portManager.clearNetworkCache",
        "title": "Port Manager: Clear Network Cache",
        "category": "Port Manager",
        "icon": "$(clear-all)"
      },
      {
        "command": "portManager.startManagedProcess",
        "title": "Port Manager: Start Managed Process",
        "category": "Port Manager"
      },
      {
        "command": "portManager.addExistingProcess",
        "title": "Port Manager: Add Existing Process",
        "category": "Port Manager"
      },
      {
        "command": "portManager.refresh",
        "title": "Port Manager: Refresh",
        "category": "Port Manager",
        "icon": "$(refresh)"
      },
      {
        "command": "portManager.showStatusMenu",
        "title": "Port Manager: Show Status Menu",
        "category": "Port Manager",
        "icon": "$(target)"
      },
      {
        "command": "portManager.openOwnerUi",
        "title": "Port Manager: Open Owner UI",
        "category": "Port Manager",
        "icon": "$(window)"
      },
      {
        "command": "portManager.stopProcess",
        "title": "Port Manager: Stop Process",
        "category": "Port Manager",
        "icon": "$(debug-stop)"
      },
      {
        "command": "portManager.restartProcess",
        "title": "Port Manager: Restart Process",
        "category": "Port Manager",
        "icon": "$(debug-restart)"
      },
      {
        "command": "portManager.stopAllProcesses",
        "title": "Port Manager: Stop All Processes",
        "category": "Port Manager",
        "icon": "$(debug-stop)"
      },
      {
        "command": "portManager.copyRoutedUrl",
        "title": "Port Manager: Copy Routed URL",
        "category": "Port Manager",
        "icon": "$(copy)"
      },
      {
        "command": "portManager.openRoutedUrl",
        "title": "Port Manager: Open Routed URL",
        "category": "Port Manager",
        "icon": "$(link-external)"
      },
      {
        "command": "portManager.removeProcess",
        "title": "Port Manager: Remove Process",
        "category": "Port Manager",
        "icon": "$(trash)"
      },
      {
        "command": "portManager.installExternalCli",
        "title": "Port Manager: Install External CLI",
        "category": "Port Manager",
        "icon": "$(terminal)"
      },
      {
        "command": "portManager.installShellHook",
        "title": "Port Manager: Install Shell Hook",
        "category": "Port Manager",
        "icon": "$(plug)"
      },
      {
        "command": "portManager.openSettings",
        "title": "Port Manager: Open Settings",
        "category": "Port Manager",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "portManager.createLogicalNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner",
          "group": "navigation@1"
        },
        {
          "command": "portManager.refresh",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner",
          "group": "navigation@2"
        },
        {
          "command": "portManager.openOwnerUi",
          "when": "view == portManager.processes && !portManager.isControlPlaneOwner",
          "group": "navigation@2"
        },
        {
          "command": "portManager.openSettings",
          "when": "view == portManager.processes",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "portManager.startDaemon",
          "when": "false"
        },
        {
          "command": "portManager.restartDaemon",
          "when": "false"
        },
        {
          "command": "portManager.stopDaemon",
          "when": "false"
        },
        {
          "command": "portManager.showDaemonStatus",
          "when": "false"
        },
        {
          "command": "portManager.startManagedProcess",
          "when": "false"
        },
        {
          "command": "portManager.addExistingProcess",
          "when": "false"
        },
        {
          "command": "portManager.stopProcess",
          "when": "false"
        },
        {
          "command": "portManager.restartProcess",
          "when": "false"
        },
        {
          "command": "portManager.stopAllProcesses",
          "when": "false"
        },
        {
          "command": "portManager.copyRoutedUrl",
          "when": "false"
        },
        {
          "command": "portManager.openRoutedUrl",
          "when": "false"
        },
        {
          "command": "portManager.removeProcess",
          "when": "false"
        },
        {
          "command": "portManager.installShellHook",
          "when": "false"
        },
        {
          "command": "portManager.installExternalCli",
          "when": "false"
        },
        {
          "command": "portManager.openOwnerUi",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "portManager.createLogicalNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == section.networks",
          "group": "network@1"
        },
        {
          "command": "portManager.addHostPortExposure",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@2"
        },
        {
          "command": "portManager.addHostAccessBinding",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@3"
        },
        {
          "command": "portManager.addComposePublishedPort",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@4"
        },
        {
          "command": "portManager.attachContainerToNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@5"
        },
        {
          "command": "portManager.attachActiveTerminalToNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@6"
        },
        {
          "command": "portManager.attachProcessToNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@7"
        },
        {
          "command": "portManager.attachVscodeWindowTerminalsToNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@8"
        },
        {
          "command": "portManager.copyTerminalRoutingScript",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@9"
        },
        {
          "command": "portManager.saveBindingPreset",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@10"
        },
        {
          "command": "portManager.applyBindingPreset",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@11"
        },
        {
          "command": "portManager.clearNetworkCache",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@12"
        },
        {
          "command": "portManager.removeLogicalNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == logicalNetwork",
          "group": "network@13"
        },
        {
          "command": "portManager.refreshContainerServices",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == section.containers",
          "group": "container@1"
        },
        {
          "command": "portManager.attachContainerToNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == section.containers",
          "group": "container@2"
        },
        {
          "command": "portManager.attachContainerToNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == containerServiceCandidate",
          "group": "container@3"
        },
        {
          "command": "portManager.attachContainerToNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == composeProjectCandidate",
          "group": "container@3"
        },
        {
          "command": "portManager.refreshTerminals",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == section.daemon",
          "group": "terminal@1"
        },
        {
          "command": "portManager.revealTerminalWindow",
          "when": "view == portManager.processes && (viewItem == terminalWindow || viewItem == terminalAttachment)",
          "group": "terminal@1"
        },
        {
          "command": "portManager.attachTerminalToNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == terminalWindow",
          "group": "terminal@2"
        },
        {
          "command": "portManager.attachVscodeWindowTerminalsToNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == section.daemon || viewItem == vscodeWindowTerminalBinding)",
          "group": "terminal@2"
        },
        {
          "command": "portManager.resetTerminalNetworkSettings",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == terminalWindow || viewItem == terminalAttachment)",
          "group": "terminal@3"
        },
        {
          "command": "portManager.detachVscodeWindowTerminalsFromNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == section.daemon || viewItem == vscodeWindowTerminalBinding)",
          "group": "terminal@3"
        },
        {
          "command": "portManager.detachTerminalFromNetwork",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == terminalAttachment",
          "group": "terminal@4"
        },
        {
          "command": "portManager.addHostPortExposure",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == section.exposures",
          "group": "exposure@1"
        },
        {
          "command": "portManager.openHostPortExposureUrl",
          "when": "view == portManager.processes && viewItem == hostExposureActive",
          "group": "inline@1"
        },
        {
          "command": "portManager.copyHostPortExposureUrl",
          "when": "view == portManager.processes && (viewItem == hostExposureActive || viewItem == hostExposure)",
          "group": "inline@2"
        },
        {
          "command": "portManager.removeHostPortExposure",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == hostExposureActive || viewItem == hostExposure)",
          "group": "exposure@3"
        },
        {
          "command": "portManager.removeHostAccessBinding",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == hostAccessBinding",
          "group": "exposure@4"
        },
        {
          "command": "portManager.copyComposeAttachment",
          "when": "view == portManager.processes && viewItem == composeAttachment",
          "group": "inline@1"
        },
        {
          "command": "portManager.detachComposeAttachment",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == composeAttachment",
          "group": "exposure@5"
        },
        {
          "command": "portManager.removeComposeAttachment",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == composeAttachment",
          "group": "exposure@7"
        },
        {
          "command": "portManager.renameComposeAttachment",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && viewItem == composeAttachment",
          "group": "exposure@6"
        },
        {
          "command": "portManager.restartDaemon",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == section.daemon || viewItem == daemonStatus)",
          "group": "daemon@1"
        },
        {
          "command": "portManager.stopDaemon",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == section.daemon || viewItem == daemonStatus)",
          "group": "daemon@2"
        },
        {
          "command": "portManager.showDaemonStatus",
          "when": "view == portManager.processes && (viewItem == section.daemon || viewItem == daemonStatus)",
          "group": "daemon@3"
        },
        {
          "command": "portManager.fixStaleRouting",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == section.daemon || viewItem == daemonStatus)",
          "group": "daemon@4"
        },
        {
          "command": "portManager.clearRoutingFiles",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == section.daemon || viewItem == daemonStatus)",
          "group": "daemon@5"
        },
        {
          "command": "portManager.clearGlobalStorageFiles",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == section.daemon || viewItem == daemonStatus)",
          "group": "daemon@6"
        },
        {
          "command": "portManager.openRoutedUrl",
          "when": "view == portManager.processes && (viewItem == managedProcessRunning || viewItem == detectedProcess)",
          "group": "inline@1"
        },
        {
          "command": "portManager.copyRoutedUrl",
          "when": "view == portManager.processes && (viewItem == managedProcessRunning || viewItem == detectedProcess)",
          "group": "inline@2"
        },
        {
          "command": "portManager.stopProcess",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == managedProcessRunning || viewItem == managedProcessStarting)",
          "group": "managed@1"
        },
        {
          "command": "portManager.restartProcess",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == managedProcessRunning || viewItem == managedProcessStopped || viewItem == managedProcessError)",
          "group": "managed@2"
        },
        {
          "command": "portManager.removeProcess",
          "when": "view == portManager.processes && portManager.isControlPlaneOwner && (viewItem == managedProcessRunning || viewItem == managedProcessStarting || viewItem == managedProcessStopped || viewItem == managedProcessError || viewItem == detectedProcess)",
          "group": "managed@3"
        }
      ]
    },
    "configuration": {
      "title": "Port Manager",
      "properties": {
        "portManager.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable managed process port routing."
        },
        "portManager.defaultHost": {
          "type": "string",
          "default": "localhost",
          "description": "Host used when building routed URLs."
        },
        "portManager.scanRange": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 200,
          "description": "Number of nearby ports to scan when the requested port is busy."
        },
        "portManager.scanDirection": {
          "type": "string",
          "default": "up",
          "enum": [
            "up",
            "down",
            "both"
          ],
          "description": "Direction used when scanning for an available nearby port."
        },
        "portManager.routingMode": {
          "type": "string",
          "default": "hashed",
          "enum": [
            "nearest",
            "hashed"
          ],
          "description": "Routing policy. Hashed keeps logical ports unoccupied and assigns actual ports from the virtual range."
        },
        "portManager.enableLoopbackAddressRouting": {
          "type": "boolean",
          "default": false,
          "description": "Legacy toggle for per-network loopback IP routing. Prefer portManager.loopbackAddressRoutingMode.",
          "deprecationMessage": "Use portManager.loopbackAddressRoutingMode instead."
        },
        "portManager.loopbackAddressRoutingMode": {
          "type": "string",
          "default": "high-port",
          "enum": [
            "high-port",
            "auto",
            "loopback"
          ],
          "enumDescriptions": [
            "Assign actual ports from the virtual high-port range on a per-network loopback address.",
            "Use same-port per-network loopback routing only when the alias already exists or can be created without prompting; otherwise attach fails closed.",
            "Use per-network loopback addresses and allow the attach script to prompt for sudo to add a missing macOS lo0 alias."
          ],
          "description": "Controls whether attached terminals keep requested ports on per-network loopback IPs or remap them to high ports on that loopback IP."
        },
        "portManager.virtualPortRangeStart": {
          "type": "number",
          "default": 53000,
          "minimum": 1,
          "maximum": 65535,
          "description": "First actual TCP port used by hashed logical routing."
        },
        "portManager.virtualPortRangeEnd": {
          "type": "number",
          "default": 59999,
          "minimum": 1,
          "maximum": 65535,
          "description": "Last actual TCP port used by hashed logical routing."
        },
        "portManager.preferredPorts": {
          "type": "array",
          "default": [
            3000,
            3001,
            5173,
            8000,
            8080
          ],
          "items": {
            "type": "number"
          },
          "description": "Common ports offered by the start command prompt."
        },
        "portManager.fixedProtocolPorts": {
          "type": "array",
          "default": [
            22,
            25,
            53,
            80,
            110,
            143,
            389,
            443,
            465,
            587,
            993,
            995,
            1433,
            1521,
            1883,
            3306,
            33060,
            4222,
            5432,
            5671,
            5672,
            6379,
            8883,
            9092,
            9200,
            9300,
            11211,
            15672,
            27017,
            50051
          ],
          "items": {
            "type": "number"
          },
          "description": "TCP ports that the native terminal hook leaves untouched because the port number itself identifies a fixed protocol such as SSH, MySQL, PostgreSQL, AMQP, MQTT, Kafka, or gRPC."
        },
        "portManager.preservedListenPorts": {
          "type": "array",
          "default": [],
          "items": {
            "type": "number"
          },
          "description": "Host-visible listener ports that terminal hooks should keep on the requested port. Leave browser dev servers out so Port Manager can provide stable network aliases."
        },
        "portManager.routeTableTtlSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "maximum": 3600,
          "description": "Seconds before generated routing cache files expire when they are not refreshed by successful routed traffic."
        },
        "portManager.containerRuntime": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "docker",
            "podman"
          ],
          "description": "Container runtime used for network-namespace holder containers."
        },
        "portManager.containerImage": {
          "type": "string",
          "default": "alpine:3.20",
          "description": "Lightweight image used only to keep a logical network namespace alive. Application processes do not run inside this image."
        },
        "portManager.autoOpenBrowser": {
          "type": "boolean",
          "default": false,
          "description": "Open the routed URL after a managed process starts."
        },
        "portManager.showConflictNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show an information notification when a busy requested port is routed."
        },
        "portManager.watchPreferredPorts": {
          "type": "boolean",
          "default": true,
          "description": "Watch preferred ports in the background and show externally occupied ports in the Port Manager sidebar."
        },
        "portManager.watchIntervalMs": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "Polling interval for watching preferred ports."
        },
        "portManager.notifyOnDetectedConflict": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when a preferred port becomes occupied by an external process."
        },
        "portManager.monitorAllListeningPorts": {
          "type": "boolean",
          "default": true,
          "description": "Show all listening TCP ports reported by the local agent, not only preferred ports."
        },
        "portManager.detectTerminalListenFailures": {
          "type": "boolean",
          "default": false,
          "description": "Legacy recovery path: detect terminal bind/listen failures and offer to rerun the command through Port Manager routing."
        },
        "portManager.routeTerminalCommandsOnStart": {
          "type": "boolean",
          "default": false,
          "description": "Legacy recovery path: when a VS Code terminal command explicitly requests a port, offer to stop it and rerun it through the Port Manager daemon before waiting for bind failure."
        },
        "portManager.processKillSignal": {
          "type": "string",
          "default": "SIGTERM",
          "description": "Signal used to stop managed processes on POSIX platforms."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.7.2"
  }
}
